<?xml version="1.0" encoding="utf-8"?>
<android.support.design.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto" android:layout_width="match_parent" android:layout_height="match_parent">
    <android.support.design.widget.AppBarLayout android:theme="@style/ThemeOverlay.AppCompat.Dark.ActionBar" android:id="@+id/app_barLayout" android:layout_width="match_parent" android:layout_height="180dp">
        <android.support.design.widget.CollapsingToolbarLayout android:id="@+id/CollapsingToolbarLayout" android:layout_width="match_parent" android:layout_height="wrap_content" app:layout_scrollFlags="exitUntilCollapsed|scroll" app:expandedTitleMarginStart="48dp" app:expandedTitleMarginEnd="64dp">
            <ImageView android:id="@+id/my_playlist_bg_img" android:layout_width="match_parent" android:layout_height="180dp" android:src="@mipmap/loadingbg" android:scaleType="centerCrop" app:layout_collapseMode="parallax"/>
            <RelativeLayout android:layout_gravity="bottom" android:id="@+id/my_playlist_desc_layout" android:layout_width="match_parent" android:layout_height="110dp">
                <com.makeramen.roundedimageview.RoundedImageView android:id="@+id/my_playlist_detail_cover_img" android:layout_width="94dp" android:layout_height="94dp" android:layout_marginLeft="16dp" android:src="@mipmap/loadingpic" android:scaleType="centerCrop" android:adjustViewBounds="true" android:elevation="5dp" app:riv_corner_radius="3dp"/>
                <com.makeramen.roundedimageview.RoundedImageView android:id="@+id/my_playlist_detail_cover_hint" android:layout_width="94dp" android:layout_height="94dp" android:layout_marginLeft="16dp" android:scaleType="centerCrop" android:adjustViewBounds="true" android:elevation="5dp" app:riv_corner_radius="3dp"/>
                <LinearLayout android:gravity="center_vertical" android:orientation="vertical" android:layout_width="wrap_content" android:layout_height="94dp" android:layout_marginLeft="126dp">
                    <com.fotoable.youtube.music.ui.view.LaToTextView android:textSize="16sp" android:textStyle="bold" android:textColor="@color/white" android:id="@+id/my_playlist_detail_big_title_tx" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/my_favorite" app:typeface="monospace"/>
                    <LinearLayout android:gravity="center_vertical" android:orientation="horizontal" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="7dp">
                        <ImageView android:layout_width="16dp" android:layout_height="16dp" android:src="@mipmap/icon_songs" android:scaleType="centerCrop" android:adjustViewBounds="true"/>
                        <com.fotoable.youtube.music.ui.view.LaToTextView android:textSize="12sp" android:textColor="@color/white" android:id="@+id/my_playlist_detail_count_tx" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginLeft="2dp" android:text="@string/songs"/>
                    </LinearLayout>
                </LinearLayout>
            </RelativeLayout>
            <android.support.v7.widget.Toolbar android:id="@+id/toolbar" android:layout_width="match_parent" android:layout_height="?android:attr/actionBarSize" android:layout_marginTop="15dp" app:layout_collapseMode="pin">
                <RelativeLayout android:layout_width="match_parent" android:layout_height="@dimen/status_bar_height">
                    <ImageView android:id="@+id/img_back" android:paddingLeft="-10dp" android:paddingTop="10dp" android:paddingRight="10dp" android:paddingBottom="10dp" android:layout_width="46dp" android:layout_height="46dp" android:src="@mipmap/icon_back" android:layout_alignParentLeft="true" android:layout_centerVertical="true"/>
                    <TextView android:textSize="18sp" android:textStyle="bold" android:textColor="@android:color/white" android:id="@+id/tv_title" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginLeft="16dp" android:layout_marginRight="20dp" android:text="@string/pop_music" android:maxLines="1" android:layout_toRightOf="@+id/img_back" android:layout_centerVertical="true"/>
                    <ImageView android:id="@+id/more_img" android:padding="10dp" android:visibility="visible" android:layout_width="29dp" android:layout_height="38dp" android:layout_marginRight="6dp" android:src="@mipmap/icon_white_more" android:adjustViewBounds="true" android:layout_alignParentRight="true" android:layout_centerVertical="true"/>
                </RelativeLayout>
            </android.support.v7.widget.Toolbar>
        </android.support.design.widget.CollapsingToolbarLayout>
    </android.support.design.widget.AppBarLayout>
    <android.support.v4.widget.NestedScrollView android:id="@+id/rel_no_data" android:background="@color/color_f7f7f7" android:visibility="gone" android:layout_width="match_parent" android:layout_height="match_parent" app:layout_behavior="@string/appbar_scrolling_view_behavior">
        <RelativeLayout android:layout_width="match_parent" android:layout_height="match_parent" android:layout_marginTop="50dp" android:layout_below="@+id/img_top" android:layout_centerHorizontal="true">
            <ImageView android:id="@+id/img_bg" android:background="@mipmap/empty_icon" android:layout_width="wrap_content" android:layout_height="wrap_content" android:scaleType="centerCrop" android:layout_centerHorizontal="true"/>
            <com.fotoable.youtube.music.ui.view.LaToTextView android:textSize="15sp" android:textColor="#9b9b9b" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="8dp" android:text="@string/no_recently" android:layout_below="@+id/img_bg" android:layout_centerHorizontal="true" app:typeface="normal"/>
        </RelativeLayout>
    </android.support.v4.widget.NestedScrollView>
    <LinearLayout android:orientation="vertical" android:layout_width="match_parent" android:layout_height="match_parent" app:layout_behavior="@string/appbar_scrolling_view_behavior">
        <android.support.v7.widget.RecyclerView android:id="@+id/recycle_view" android:background="@color/white" android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1" app:layout_behavior="@string/appbar_scrolling_view_behavior"/>
        <View android:id="@+id/empty_bottom_bar" android:layout_width="match_parent" android:layout_height="56dp"/>
    </LinearLayout>
    <include layout="@layout/view_player_bar"/>
    <Button android:layout_gravity="top|right" android:id="@+id/my_playlist_play_all_btn" android:background="@drawable/check_playall_selector" android:layout_width="45dp" android:layout_height="45dp" android:layout_marginTop="-22.5dp" android:layout_marginRight="25.5dp" app:layout_behavior="@string/appbar_scrolling_view_behavior"/>
</android.support.design.widget.CoordinatorLayout>
