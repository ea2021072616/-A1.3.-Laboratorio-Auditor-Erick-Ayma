        </clip>
    </item>
    <item android:id="@android:id/progress" android:paddingTop="1dp" android:paddingBottom="1dp">
        <clip>
            <shape>
                <corners android:radius="1dp"/>
                <solid android:color="@color/color_ff2d55"/>
            </shape>
        </clip>
    </item>
</layer-list>
