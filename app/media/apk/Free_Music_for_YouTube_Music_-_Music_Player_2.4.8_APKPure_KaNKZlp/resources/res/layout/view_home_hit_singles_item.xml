<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto" android:id="@+id/rl_details" android:background="@drawable/click_status" android:clickable="true" android:layout_width="match_parent" android:layout_height="86dp">
    <ImageView android:id="@+id/iv_icon" android:background="@mipmap/pic_recently" android:layout_width="110dp" android:layout_height="62dp" android:layout_marginLeft="16dp" android:layout_marginRight="8dp" android:scaleType="centerCrop" android:layout_centerVertical="true"/>
    <com.fotoable.youtube.music.ui.view.LaToTextView android:textSize="10sp" android:textColor="@color/white" android:gravity="center" android:id="@+id/text_time" android:background="#b9000000" android:paddingLeft="5dp" android:paddingRight="5dp" android:layout_width="wrap_content" android:layout_height="15dp" android:text="04:32" android:layout_alignRight="@+id/iv_icon" android:layout_alignBottom="@+id/iv_icon"/>
    <LinearLayout android:orientation="vertical" android:id="@+id/lin_desc" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginRight="1dp" android:layout_toRightOf="@+id/iv_icon" android:layout_centerVertical="true">
        <com.fotoable.youtube.music.ui.view.LaToTextView android:textSize="14sp" android:textColor="#2b2525" android:ellipsize="end" android:id="@+id/txt_title" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="-2dp" android:text="Type something ab Video Name" android:maxLines="2" android:layout_weight="1" app:typeface="normal"/>
        <com.fotoable.youtube.music.ui.view.LaToTextView android:textSize="12sp" android:textColor="#676767" android:ellipsize="end" android:id="@+id/txt_content" android:visibility="gone" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="6dp" android:maxLines="1" android:layout_weight="1" app:typeface="normal"/>
    </LinearLayout>
    <View android:id="@+id/line" android:background="@color/color_e8e8e8" android:layout_width="match_parent" android:layout_height="0.5dp" android:layout_marginLeft="16dp" android:layout_alignParentBottom="true"/>
</RelativeLayout>
