<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto" android:orientation="vertical" android:layout_width="match_parent" android:layout_height="match_parent">
    <RelativeLayout android:background="@drawable/shape_white_corner" android:paddingBottom="15dp" android:layout_width="310dp" android:layout_height="wrap_content">
        <ImageView android:id="@+id/close_img" android:padding="10dp" android:layout_width="32dp" android:layout_height="wrap_content" android:src="@mipmap/icon_close_grey" android:scaleType="centerCrop" android:adjustViewBounds="true" android:layout_alignParentRight="true"/>
        <LinearLayout android:orientation="vertical" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="18dp">
            <ImageView android:id="@+id/cover_img" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginLeft="30dp" android:layout_marginRight="30dp" android:src="@mipmap/icon_app_update" android:scaleType="centerCrop" android:adjustViewBounds="true"/>
            <com.fotoable.youtube.music.ui.view.LaToTextView android:textSize="18sp" android:textStyle="bold" android:textColor="@color/white" android:gravity="center" android:id="@+id/ok_tx" android:background="@drawable/bt_clear_border" android:layout_width="match_parent" android:layout_height="36dp" android:layout_marginLeft="20dp" android:layout_marginTop="15dp" android:layout_marginRight="20dp" android:text="@string/update_now" app:typeface="monospace"/>
            <com.fotoable.youtube.music.ui.view.LaToTextView android:textSize="16sp" android:textColor="@color/color_9b9b8c" android:gravity="center" android:id="@+id/cancel_tx" android:layout_width="match_parent" android:layout_height="36dp" android:layout_marginLeft="20dp" android:layout_marginTop="15dp" android:layout_marginRight="20dp" android:text="@string/later"/>
        </LinearLayout>
    </RelativeLayout>
</LinearLayout>
