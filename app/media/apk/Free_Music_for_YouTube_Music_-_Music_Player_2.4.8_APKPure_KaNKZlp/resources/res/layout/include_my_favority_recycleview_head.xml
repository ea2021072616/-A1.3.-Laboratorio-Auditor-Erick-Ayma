<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto" android:orientation="vertical" android:background="#f7f7f7" android:paddingTop="6dp" android:paddingBottom="6dp" android:fitsSystemWindows="false" android:layout_width="match_parent" android:layout_height="wrap_content">
    <RelativeLayout android:id="@+id/rel_play_all" android:layout_width="wrap_content" android:layout_height="wrap_content">
        <ImageView android:id="@+id/img_icon" android:layout_width="24dp" android:layout_height="24.5dp" android:layout_marginLeft="16dp" android:src="@mipmap/icon_playnow" android:scaleType="centerCrop" android:layout_centerVertical="true"/>
        <TextView android:textSize="14sp" android:textColor="#2b2525" android:id="@+id/txt_play_all" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginLeft="6dp" android:text="@string/play_all" android:layout_toRightOf="@+id/img_icon" android:layout_centerVertical="true"/>
        <TextView android:textSize="9sp" android:textColor="#6d6363" android:id="@+id/txt_songs" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginLeft="6dp" android:text="(4 songs)" android:layout_toRightOf="@+id/txt_play_all" android:layout_centerVertical="true"/>
    </RelativeLayout>
    <TextView android:textSize="12sp" android:textColor="#ff2d55" android:id="@+id/txt_clear" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginRight="16dp" android:text="@string/clear_all" android:layout_alignParentRight="true" android:layout_centerVertical="true"/>
</RelativeLayout>
