<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto" android:orientation="vertical" android:background="@drawable/bg_white_radius_3dp" android:paddingBottom="0dp" android:layout_width="330dp" android:layout_height="wrap_content">
    <RelativeLayout android:background="@drawable/bg_white_radius_3dp" android:layout_width="match_parent" android:layout_height="44dp">
        <com.fotoable.youtube.music.ui.view.LaToTextView android:textSize="14sp" android:textColor="@color/color_2b2525" android:ellipsize="end" android:gravity="center_vertical" android:id="@+id/video_title" android:layout_width="match_parent" android:layout_height="44dp" android:layout_marginLeft="12dp" android:text="Type something abVideo Name" android:maxLines="1" android:layout_toLeftOf="@+id/ad_close" app:typeface="normal"/>
        <ImageView android:id="@+id/ad_close" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginRight="8dp" android:src="@mipmap/icon_ad_close" android:layout_alignParentRight="true" android:layout_centerVertical="true"/>
    </RelativeLayout>
    <RelativeLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:minHeight="200dp">
        <FrameLayout android:id="@+id/adview_parent" android:layout_width="match_parent" android:layout_height="wrap_content"/>
    </RelativeLayout>
    <View android:background="@color/color_d9cfd1" android:layout_width="match_parent" android:layout_height="0.5dp"/>
    <LinearLayout android:orientation="horizontal" android:layout_width="match_parent" android:layout_height="42dp">
        <LinearLayout android:gravity="center" android:id="@+id/video_play" android:background="@drawable/bg_press_change_left" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1">
            <ImageView android:layout_width="wrap_content" android:layout_height="wrap_content" android:src="@mipmap/icon_ad_play"/>
            <com.fotoable.youtube.music.ui.view.LaToTextView android:textSize="16sp" android:textColor="#ffff2d55" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginLeft="8dp" android:text="Play" app:typeface="monospace"/>
        </LinearLayout>
        <View android:background="@color/color_d9cfd1" android:layout_width="0.5dp" android:layout_height="match_parent"/>
        <LinearLayout android:gravity="center" android:id="@+id/search_mp3" android:background="@drawable/bg_press_change_right" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1">
            <ImageView android:layout_width="wrap_content" android:layout_height="wrap_content" android:src="@mipmap/icon_ad_mp3"/>
            <com.fotoable.youtube.music.ui.view.LaToTextView android:textSize="16sp" android:textColor="#ffff2d55" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginLeft="8dp" android:text="@string/mp3" app:typeface="monospace"/>
        </LinearLayout>
    </LinearLayout>
</LinearLayout>
