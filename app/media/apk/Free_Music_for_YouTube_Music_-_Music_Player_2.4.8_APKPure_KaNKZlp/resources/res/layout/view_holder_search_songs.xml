<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto" android:layout_width="match_parent" android:layout_height="86dp">
    <LinearLayout android:gravity="center_vertical" android:orientation="horizontal" android:paddingBottom="0.5dp" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginLeft="16dp" android:layout_marginRight="16dp" android:layout_centerVertical="true">
        <RelativeLayout android:layout_width="100dp" android:layout_height="56dp">
            <ImageView android:id="@+id/adapter_search_song_cover_img" android:layout_width="100dp" android:layout_height="56dp" android:scaleType="centerCrop" android:adjustViewBounds="true"/>
            <com.fotoable.youtube.music.ui.view.LaToTextView android:textSize="7sp" android:textColor="@color/white" android:id="@+id/adapter_search_song_duration_tx" android:background="@color/black" android:padding="3dp" android:visibility="gone" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_alignParentRight="true" android:layout_alignParentBottom="true"/>
        </RelativeLayout>
        <com.fotoable.youtube.music.ui.view.LaToTextView android:textSize="14sp" android:textColor="@color/color_2b2525" android:ellipsize="end" android:id="@+id/adapter_search_song_name_tx" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginLeft="8dp" android:layout_marginRight="70dp" android:maxLines="2"/>
    </LinearLayout>
    <ImageView android:id="@+id/adapter_search_song_menu_img" android:padding="17dp" android:layout_width="37dp" android:layout_height="wrap_content" android:src="@mipmap/menu_right" android:scaleType="centerCrop" android:adjustViewBounds="true" android:layout_alignParentRight="true" android:layout_centerVertical="true"/>
    <View android:background="@color/color_d9cfd1" android:layout_width="match_parent" android:layout_height="0.5dp" android:layout_alignParentBottom="true"/>
</RelativeLayout>
