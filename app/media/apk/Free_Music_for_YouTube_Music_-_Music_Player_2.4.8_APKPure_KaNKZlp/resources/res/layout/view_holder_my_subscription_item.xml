<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android" android:orientation="vertical" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginBottom="10dp">
    <RelativeLayout android:layout_width="match_parent" android:layout_height="98dp">
        <ImageView android:id="@+id/sub_cover" android:background="@color/bg_d8_3" android:layout_width="98dp" android:layout_height="98dp" android:scaleType="centerCrop"/>
        <LinearLayout android:orientation="vertical" android:layout_width="match_parent" android:layout_height="match_parent" android:layout_marginLeft="16dp" android:layout_toRightOf="@+id/sub_cover">
            <TextView android:textSize="16sp" android:textColor="#000" android:gravity="center_vertical" android:layout_width="wrap_content" android:layout_height="0dp" android:text="Pop Music" android:layout_weight="2"/>
            <TextView android:gravity="center_vertical" android:layout_width="wrap_content" android:layout_height="0dp" android:text="12 New Videos" android:layout_weight="1"/>
            <TextView android:gravity="center_vertical" android:layout_width="wrap_content" android:layout_height="0dp" android:text="Update 2017-05" android:layout_weight="1"/>
        </LinearLayout>
        <ImageView android:layout_width="wrap_content" android:layout_height="wrap_content" android:src="@mipmap/arrow_right" android:tint="@color/bg_d8_3" android:layout_alignParentRight="true" android:layout_centerVertical="true"/>
    </RelativeLayout>
</LinearLayout>
