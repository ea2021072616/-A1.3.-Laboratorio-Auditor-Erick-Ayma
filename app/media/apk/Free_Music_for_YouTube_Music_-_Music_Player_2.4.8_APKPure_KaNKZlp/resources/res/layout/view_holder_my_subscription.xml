<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android" android:orientation="vertical" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginLeft="16dp" android:layout_marginRight="16dp">
    <RelativeLayout android:layout_width="match_parent" android:layout_height="50dp">
        <TextView android:textSize="16sp" android:textColor="#000" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="My Subscription" android:layout_centerVertical="true"/>
        <TextView android:textSize="16sp" android:textColor="@color/colorAccent" android:id="@+id/view_all" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="View All" android:layout_alignParentRight="true" android:layout_centerVertical="true"/>
    </RelativeLayout>
    <android.support.v7.widget.RecyclerView android:id="@+id/recycle_view" android:layout_width="match_parent" android:layout_height="wrap_content"/>
</LinearLayout>
