<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto" android:background="@color/color_f7f7f7" android:fitsSystemWindows="false" android:layout_width="match_parent" android:layout_height="match_parent">
    <ImageView android:layout_width="match_parent" android:layout_height="80dp" android:src="@mipmap/pic_top" android:scaleType="centerCrop"/>
    <RelativeLayout android:layout_width="match_parent" android:layout_height="60dp" android:layout_marginTop="20dp">
        <EditText android:textSize="14sp" android:textColor="@color/tc_27_3" android:textColorHint="@color/color_9b9b9b" android:id="@+id/search_edit" android:background="@drawable/shape_search_corner" android:paddingLeft="45dp" android:paddingRight="40dp" android:layout_width="match_parent" android:layout_height="40dp" android:layout_marginLeft="16dp" android:layout_marginTop="10dp" android:layout_marginRight="76dp" android:layout_marginBottom="10dp" android:hint="@string/search_music" android:maxLines="1" android:layout_centerVertical="true" android:inputType="text" android:imeOptions="actionSearch"/>
        <ImageView android:layout_width="32dp" android:layout_height="wrap_content" android:layout_marginLeft="25dp" android:src="@mipmap/icon_search_grey" android:scaleType="centerCrop" android:adjustViewBounds="true" android:layout_centerVertical="true"/>
        <ImageView android:id="@+id/search_delete_img" android:padding="10dp" android:visibility="gone" android:layout_width="40dp" android:layout_height="wrap_content" android:layout_marginRight="80dp" android:src="@mipmap/icon_delete_history" android:scaleType="centerCrop" android:adjustViewBounds="true" android:layout_alignParentRight="true" android:layout_centerVertical="true"/>
        <com.fotoable.youtube.music.ui.view.LaToTextView android:textSize="14sp" android:textStyle="bold" android:textColor="@color/white" android:gravity="center" android:id="@+id/search_cancel_tx" android:paddingLeft="16dp" android:paddingRight="16dp" android:layout_width="wrap_content" android:layout_height="60dp" android:text="@string/cancel" android:layout_alignParentRight="true" android:layout_centerVertical="true"/>
    </RelativeLayout>
    <LinearLayout android:orientation="vertical" android:id="@+id/search_result_view" android:background="@color/color_f7f7f7" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="80dp">
        <com.flyco.tablayout.SlidingTabLayout android:layout_gravity="center_vertical" android:id="@+id/search_tab_layout" android:background="@color/color_f7f7f7" android:layout_width="match_parent" android:layout_height="44dp" app:tl_indicator_color="@color/color_ff2d55" app:tl_indicator_height="3dp" app:tl_indicator_width="70dp" app:tl_tab_space_equal="true" app:tl_textBold="NONE" app:tl_textSelectColor="@color/color_ff2d55" app:tl_textUnselectColor="@color/color_676767" app:tl_textsize="14sp"/>
        <RelativeLayout android:layout_width="match_parent" android:layout_height="match_parent">
            <android.support.v4.view.ViewPager android:id="@+id/search_view_pager" android:background="@color/color_f7f7f7" android:layout_width="match_parent" android:layout_height="match_parent"/>
            <View android:background="@mipmap/ic_shadow" android:layout_width="match_parent" android:layout_height="5dp"/>
        </RelativeLayout>
    </LinearLayout>
    <ListView android:id="@+id/search_history_list_view" android:background="@color/color_f7f7f7" android:layout_width="match_parent" android:layout_height="match_parent" android:layout_marginTop="80dp" android:divider="@color/all_alpha" android:dividerHeight="0dp"/>
    <ListView android:id="@+id/search_suggest_list_view" android:background="@color/color_f7f7f7" android:paddingLeft="16dp" android:visibility="gone" android:layout_width="match_parent" android:layout_height="match_parent" android:layout_marginTop="80dp" android:divider="@color/color_d9cfd1" android:dividerHeight="0.5dp"/>
    <View android:id="@+id/search_history_title_shadow_view" android:background="@mipmap/ic_shadow" android:layout_width="match_parent" android:layout_height="5dp" android:layout_marginTop="80dp"/>
</RelativeLayout>
