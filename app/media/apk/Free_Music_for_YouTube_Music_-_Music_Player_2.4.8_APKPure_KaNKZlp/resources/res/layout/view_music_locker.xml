<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto" android:layout_width="match_parent" android:layout_height="match_parent">
    <RelativeLayout android:id="@+id/root_view" android:layout_width="match_parent" android:layout_height="match_parent">
        <ImageView android:id="@+id/wallpaper_blur" android:layout_width="match_parent" android:layout_height="match_parent" android:src="@mipmap/float_player_bg" android:scaleType="centerCrop"/>
        <ImageView android:id="@+id/wallpaper_blur_on_alpha_black" android:background="#2e000000" android:layout_width="match_parent" android:layout_height="match_parent"/>
        <ImageView android:id="@+id/menu_more" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="8dp" android:layout_marginRight="2dp" android:src="@mipmap/float_big_more" android:layout_alignParentRight="true"/>
        <LinearLayout android:orientation="vertical" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginLeft="16dp" android:layout_marginTop="10dp" android:alpha="0.6">
            <ImageView android:id="@+id/locker_logo" android:layout_width="15dp" android:layout_height="15dp" android:src="@mipmap/notification_logo"/>
            <com.fotoable.youtube.music.ui.view.LaToTextView android:textSize="10sp" android:textColor="@color/white" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="2dp" android:text="@string/app_name" android:includeFontPadding="false"/>
        </LinearLayout>
        <LinearLayout android:orientation="vertical" android:id="@+id/battery_lock_panel" android:layout_width="match_parent" android:layout_height="match_parent">
            <com.fotoable.youtube.music.locker.view.BatteryView01 android:id="@+id/battery_view" android:layout_width="wrap_content" android:layout_height="match_parent"/>
        </LinearLayout>
        <LinearLayout android:gravity="center_horizontal" android:orientation="vertical" android:id="@+id/music_info_panel" android:visibility="gone" android:layout_width="match_parent" android:layout_height="match_parent">
            <RelativeLayout android:gravity="center_horizontal" android:orientation="vertical" android:paddingLeft="16dp" android:paddingRight="16dp" android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="260">
                <com.fotoable.youtube.music.ui.view.LaToTextView android:textSize="17sp" android:textColor="@color/white" android:ellipsize="end" android:gravity="center" android:id="@+id/music_title" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Song Name" android:maxLines="2" android:shadowColor="#26000000" android:shadowDx="0" android:shadowDy="1" android:shadowRadius="2" android:layout_above="@+id/music_artists" android:layout_centerHorizontal="true" app:typeface="5"/>
                <com.fotoable.youtube.music.ui.view.LaToTextView android:textSize="14sp" android:textColor="#ccffffff" android:ellipsize="end" android:gravity="center" android:id="@+id/music_artists" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="8dp" android:layout_marginBottom="4dp" android:text="Artists Name" android:maxLines="2" android:shadowColor="#26000000" android:shadowDx="0" android:shadowDy="1" android:shadowRadius="2" android:layout_alignParentBottom="true" android:layout_centerHorizontal="true" app:typeface="normal"/>
            </RelativeLayout>
            <RelativeLayout android:id="@+id/radio_cover_panel" android:visibility="gone" android:layout_width="wrap_content" android:layout_height="265dp">
                <RelativeLayout android:layout_width="255dp" android:layout_height="205dp" android:layout_centerInParent="true">
                    <ImageView android:layout_width="match_parent" android:layout_height="match_parent" android:src="@mipmap/player_radio_style"/>
                    <LinearLayout android:orientation="horizontal" android:layout_width="match_parent" android:layout_height="match_parent">
                        <View android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1"/>
                        <RelativeLayout android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1">
                            <ImageView android:background="@drawable/border_player_radio" android:layout_width="78dp" android:layout_height="54dp" android:layout_centerInParent="true"/>
                            <ImageView android:id="@+id/radio_cover_img" android:layout_width="72dp" android:layout_height="49.5dp" android:src="@mipmap/icon_radio_default" android:scaleType="centerCrop" android:layout_centerInParent="true"/>
                        </RelativeLayout>
                    </LinearLayout>
                </RelativeLayout>
            </RelativeLayout>
            <RelativeLayout android:id="@+id/music_cover_panel" android:visibility="visible" android:layout_width="wrap_content" android:layout_height="wrap_content">
                <ImageView android:layout_width="265dp" android:layout_height="265dp" android:src="@drawable/locker_music_cover_shadow"/>
                <com.makeramen.roundedimageview.RoundedImageView android:id="@+id/player_cover" android:layout_width="211dp" android:layout_height="211dp" android:src="@drawable/locker_music_def_cover" android:scaleType="centerCrop" android:adjustViewBounds="true" android:layout_centerInParent="true" app:riv_corner_radius="10dp"/>
            </RelativeLayout>
            <RelativeLayout android:gravity="center_horizontal" android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="459">
                <LinearLayout android:orientation="horizontal" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="43dp">
                    <ImageView android:id="@+id/player_previous" android:visibility="visible" android:layout_width="wrap_content" android:layout_height="wrap_content" android:src="@drawable/locker_playback"/>
                    <ImageView android:id="@+id/player_state" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginLeft="22dp" android:src="@drawable/locker_play_state"/>
                    <ImageView android:id="@+id/player_next" android:visibility="visible" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginLeft="22dp" android:src="@drawable/locker_play_next"/>
                    <ImageView android:id="@+id/player_fav" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginLeft="22dp" android:src="@drawable/locker_fav_state"/>
                </LinearLayout>
            </RelativeLayout>
        </LinearLayout>
        <ImageView android:id="@+id/locker_bottom_bar_panel_bg" android:layout_width="match_parent" android:layout_height="50dp" android:src="@drawable/bg_locker_bottom_bar" android:scaleType="fitXY" android:layout_alignParentBottom="true"/>
        <LinearLayout android:id="@+id/locker_bottom_bar_panel" android:layout_width="match_parent" android:layout_height="50dp" android:layout_alignParentBottom="true">
            <RelativeLayout android:gravity="center_vertical" android:layout_gravity="center_vertical" android:id="@+id/bar_1" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1">
                <com.fotoable.youtube.music.ui.view.LaToTextView android:textSize="32sp" android:textColor="#ccffffff" android:id="@+id/locker_time" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginLeft="12dp" android:text="12:03" app:typeface="5"/>
                <com.fotoable.youtube.music.ui.view.LaToTextView android:textSize="13sp" android:textColor="#ccffffff" android:id="@+id/locker_month" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginLeft="8dp" android:text="Tue" android:layout_toRightOf="@+id/locker_time" android:layout_alignBaseline="@+id/locker_time" app:typeface="4"/>
                <com.fotoable.youtube.music.ui.view.LaToTextView android:textSize="13sp" android:textColor="#ccffffff" android:id="@+id/locker_days" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginLeft="8dp" android:text="08.09" android:layout_toRightOf="@+id/locker_month" android:layout_alignBaseline="@+id/locker_month" app:typeface="4"/>
            </RelativeLayout>
            <LinearLayout android:gravity="bottom" android:layout_gravity="center_vertical" android:orientation="horizontal" android:layout_width="0dp" android:layout_height="30dp" android:layout_weight="1">
                <com.fotoable.youtube.music.locker.view.shimmer.ShimmerFrameLayout android:layout_gravity="center" android:id="@+id/shimmer_view_container" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginLeft="18dp" android:layout_marginBottom="2dp">
                    <ImageView android:id="@+id/slide_img" android:layout_width="wrap_content" android:layout_height="wrap_content" android:src="@drawable/bt_locker_slide"/>
                </com.fotoable.youtube.music.locker.view.shimmer.ShimmerFrameLayout>
                <com.fotoable.youtube.music.ui.view.MarqueeTextView android:textSize="16sp" android:textColor="#ccffffff" android:ellipsize="end" android:gravity="bottom" android:id="@+id/slide_to_unlock_tv" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginLeft="14dp" android:text="@string/slide_to_unlock" android:singleLine="true" android:includeFontPadding="false" app:typeface="4"/>
            </LinearLayout>
        </LinearLayout>
    </RelativeLayout>
</RelativeLayout>
