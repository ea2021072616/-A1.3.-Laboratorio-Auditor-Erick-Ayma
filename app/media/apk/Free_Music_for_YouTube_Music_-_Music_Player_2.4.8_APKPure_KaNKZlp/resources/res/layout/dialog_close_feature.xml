<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto" android:orientation="vertical" android:background="@drawable/bg_dialog_tip" android:paddingBottom="8dp" android:layout_width="320dp" android:layout_height="wrap_content">
    <ImageView android:id="@+id/img_warning" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="28dp" android:src="@mipmap/ic_warning" android:layout_centerHorizontal="true"/>
    <com.fotoable.youtube.music.ui.view.LaToTextView android:textSize="15sp" android:textColor="@color/black" android:id="@+id/tv_desc" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginLeft="16dp" android:layout_marginTop="22dp" android:layout_marginRight="16dp" android:layout_below="@+id/img_warning"/>
    <LinearLayout android:orientation="horizontal" android:layout_width="match_parent" android:layout_height="36dp" android:layout_marginLeft="16dp" android:layout_marginTop="34dp" android:layout_marginRight="16dp" android:layout_marginBottom="30dp" android:layout_below="@+id/tv_desc">
        <com.fotoable.youtube.music.ui.view.LaToTextView android:textSize="15sp" android:textColor="@color/color_b6afb0" android:gravity="center" android:id="@+id/btn_turn_off" android:background="@drawable/dialog_btn_grey_selector" android:layout_width="0dp" android:layout_height="36dp" android:text="@string/turn_off" android:layout_weight="1" app:typeface="monospace"/>
        <View android:layout_width="18dp" android:layout_height="1dp"/>
        <com.fotoable.youtube.music.ui.view.LaToTextView android:textSize="15sp" android:textColor="@color/white" android:gravity="center" android:id="@+id/btn_keep_it" android:background="@drawable/dialog_btn_red_selector" android:layout_width="0dp" android:layout_height="36dp" android:text="@string/keep_it" android:layout_weight="1" app:typeface="monospace"/>
    </LinearLayout>
</RelativeLayout>
