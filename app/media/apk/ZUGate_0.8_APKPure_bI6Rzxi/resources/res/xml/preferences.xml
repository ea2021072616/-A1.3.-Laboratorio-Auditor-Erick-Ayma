<?xml version="1.0" encoding="utf-8"?>
<PreferenceScreen xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto">
    <PreferenceCategory app:iconSpaceReserved="false" app:title="@string/main_options">
        <SwitchPreferenceCompat app:defaultValue="true" app:iconSpaceReserved="false" app:key="usb_startup" app:title="@string/usb_startup"/>
        <SwitchPreferenceCompat app:defaultValue="false" app:iconSpaceReserved="false" app:key="hw_use" app:title="@string/hw_use"/>
        <ru.zdevs.zugate.widget.HWListPreference android:dependency="hw_use" app:defaultValue="true" app:iconSpaceReserved="false" app:key="hw_config" app:title="@string/hw_config"/>
    </PreferenceCategory>
    <PreferenceCategory app:iconSpaceReserved="false" app:title="@string/file_provider">
        <SwitchPreferenceCompat app:defaultValue="true" app:iconSpaceReserved="false" app:key="group_storage" app:title="@string/group_storage_in_one_device"/>
        <SwitchPreferenceCompat app:defaultValue="false" app:iconSpaceReserved="false" app:key="allow_write" app:title="@string/allow_write_operation"/>
        <SwitchPreferenceCompat app:defaultValue="false" app:iconSpaceReserved="false" app:key="allow_root" app:title="@string/allow_root_mounting"/>
    </PreferenceCategory>
    <PreferenceCategory app:iconSpaceReserved="false" app:title="@string/help">
        <Preference app:iconSpaceReserved="false" app:key="user_guide" app:title="@string/user_guide"/>
        <Preference app:iconSpaceReserved="false" app:key="donate" app:title="@string/donate"/>
        <Preference app:iconSpaceReserved="false" app:key="oss" app:title="@string/oss"/>
        <Preference app:iconSpaceReserved="false" app:key="app_name" app:summary="@string/app_about" app:title="@string/app_name"/>
    </PreferenceCategory>
</PreferenceScreen>
