<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto" android:background="@color/bg_item" android:layout_width="match_parent" android:layout_height="match_parent">
    <ImageView android:layout_width="match_parent" android:layout_height="80dp" android:src="@mipmap/pic_top" android:scaleType="centerCrop"/>
    <RelativeLayout android:id="@+id/tool_bar_panel" android:layout_width="match_parent" android:layout_height="54dp" android:layout_marginTop="26dp">
        <ImageView android:id="@+id/back_view" android:padding="10dp" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginLeft="8dp" android:src="@mipmap/icon_back" android:layout_centerVertical="true"/>
        <com.fotoable.youtube.music.ui.view.LaToTextView android:textSize="18sp" android:textColor="@color/white" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginLeft="15dp" android:text="@string/community_post_title" android:layout_toRightOf="@+id/back_view" android:layout_centerVertical="true" app:typeface="monospace"/>
        <com.fotoable.youtube.music.ui.view.LaToTextView android:textSize="16sp" android:textColor="@color/white" android:id="@+id/tv_post_send" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginRight="16dp" android:text="@string/community_post_send_btn" android:layout_alignParentRight="true" android:layout_centerVertical="true" app:typeface="normal"/>
    </RelativeLayout>
    <ScrollView android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_below="@+id/tool_bar_panel">
        <LinearLayout android:orientation="vertical" android:background="@color/white" android:paddingLeft="16dp" android:paddingRight="16dp" android:layout_width="match_parent" android:layout_height="wrap_content">
            <RelativeLayout android:id="@+id/rl_post_type_panel" android:layout_width="match_parent" android:layout_height="40dp">
                <com.fotoable.youtube.music.ui.view.LaToTextView android:textSize="14sp" android:textColor="@color/color_9b9b9b" android:id="@+id/tv_community_post_type" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/community_post_type" android:layout_centerVertical="true" app:typeface="normal"/>
                <com.fotoable.youtube.music.ui.view.LaToTextView android:textSize="14sp" android:textColor="@color/color_343434" android:gravity="center_vertical" android:id="@+id/tv_post_type" android:paddingRight="16dp" android:layout_width="match_parent" android:layout_height="match_parent" android:layout_marginLeft="16dp" android:text="@string/music_resources" android:layout_toLeftOf="@+id/iv_chevron_down" android:layout_toRightOf="@+id/tv_community_post_type" android:layout_centerVertical="true" app:typeface="normal"/>
                <ImageView android:id="@+id/iv_chevron_down" android:layout_width="wrap_content" android:layout_height="wrap_content" android:src="@drawable/chevron_down" android:layout_alignParentRight="true" android:layout_centerVertical="true"/>
                <View android:background="@color/line_color" android:layout_width="match_parent" android:layout_height="0.5dp" android:layout_alignParentBottom="true"/>
            </RelativeLayout>
            <RelativeLayout android:layout_width="match_parent" android:layout_height="wrap_content">
                <LinearLayout android:orientation="vertical" android:layout_width="match_parent" android:layout_height="wrap_content">
                    <EditText android:textSize="14sp" android:textColorHint="#c8c7cc" android:gravity="top|left" android:id="@+id/et_post_content" android:background="@color/white" android:paddingTop="10dp" android:layout_width="match_parent" android:layout_height="58dp" android:hint="@string/write_something_about_music"/>
                    <android.support.v7.widget.RecyclerView android:id="@+id/rv_post_image" android:layout_width="match_parent" android:layout_height="wrap_content"/>
                    <View android:background="@color/line_color" android:layout_width="match_parent" android:layout_height="0.5dp" android:layout_marginTop="10dp" android:layout_alignParentBottom="true"/>
                    <RelativeLayout android:id="@+id/ll_post_video" android:layout_width="match_parent" android:layout_height="50dp">
                        <RelativeLayout android:layout_width="53dp" android:layout_height="33dp" android:layout_centerVertical="true">
                            <ImageView android:id="@+id/iv_post_video_cover" android:layout_width="match_parent" android:layout_height="match_parent" android:src="@mipmap/pic_recently" android:scaleType="centerCrop"/>
                            <com.fotoable.youtube.music.ui.view.LaToTextView android:textSize="7sp" android:textColor="@color/white" android:gravity="center" android:id="@+id/tv_post_video_time" android:background="#b9000000" android:paddingLeft="3dp" android:paddingRight="3dp" android:visibility="gone" android:layout_width="wrap_content" android:layout_height="12dp" android:text="4:32" android:layout_alignRight="@+id/iv_icon" android:layout_alignBottom="@+id/iv_icon" android:layout_alignParentRight="true" android:layout_alignParentBottom="true"/>
                        </RelativeLayout>
                        <LinearLayout android:orientation="vertical" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginLeft="61dp" android:layout_marginRight="8dp" android:layout_toLeftOf="@+id/arrow_right" android:layout_centerVertical="true">
                            <com.fotoable.youtube.music.ui.view.LaToTextView android:textSize="14sp" android:textColor="#2b2525" android:ellipsize="end" android:id="@+id/tv_post_video_title" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="-2dp" android:text="@string/add_music_here" android:maxLines="2" android:layout_weight="1" app:typeface="normal"/>
                            <com.fotoable.youtube.music.ui.view.LaToTextView android:textSize="12sp" android:textColor="#ff676767" android:ellipsize="end" android:id="@+id/tv_post_video_artists" android:visibility="gone" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="0dp" android:text="Type something ab Video Name" android:maxLines="1" android:layout_weight="1" app:typeface="normal"/>
                        </LinearLayout>
                        <ImageView android:id="@+id/arrow_right" android:layout_width="wrap_content" android:layout_height="wrap_content" android:src="@mipmap/arrow_right" android:layout_alignParentRight="true" android:layout_centerVertical="true"/>
                    </RelativeLayout>
                </LinearLayout>
            </RelativeLayout>
        </LinearLayout>
    </ScrollView>
</RelativeLayout>
