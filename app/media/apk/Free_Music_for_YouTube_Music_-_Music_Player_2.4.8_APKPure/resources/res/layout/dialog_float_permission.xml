        <ImageView android:id="@+id/float_permission_tip_img" android:layout_width="match_parent" android:layout_height="135dp" android:scaleType="centerCrop"/>
        <com.fotoable.youtube.music.ui.view.LaToTextView android:textSize="16sp" android:textColor="@color/color_343434" android:id="@+id/content" android:paddingLeft="16dp" android:paddingRight="16dp" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/float_permission_tip_description" app:typeface="normal"/>
