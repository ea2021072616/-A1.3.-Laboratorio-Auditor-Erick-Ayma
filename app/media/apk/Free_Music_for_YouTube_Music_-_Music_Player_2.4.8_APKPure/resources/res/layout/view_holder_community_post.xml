<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto" android:orientation="vertical" android:background="@color/white" android:paddingTop="16dp" android:layout_width="match_parent" android:layout_height="wrap_content">
    <RelativeLayout android:paddingLeft="10dp" android:paddingRight="10dp" android:layout_width="match_parent" android:layout_height="37dp">
        <RelativeLayout android:id="@+id/rl_user_avatar" android:layout_width="40dp" android:layout_height="36dp" android:layout_centerVertical="true">
            <com.makeramen.roundedimageview.RoundedImageView android:id="@+id/iv_user_avatar" android:background="@drawable/border_comment_user_avatar" android:layout_width="36dp" android:layout_height="36dp" android:src="@drawable/user_avatar_def" app:riv_corner_radius="18dp"/>
            <ImageView android:id="@+id/iv_vip_mark_icon" android:visibility="gone" android:layout_width="16dp" android:layout_height="16dp" android:src="@drawable/vip_mark_icon" android:layout_alignParentRight="true" android:layout_alignParentBottom="true"/>
        </RelativeLayout>
        <com.fotoable.youtube.music.ui.view.LaToTextView android:textSize="14sp" android:textColor="@color/color_9b9b9b" android:ellipsize="end" android:id="@+id/tv_user_name" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginLeft="8dp" android:text="User&apos;s name" android:maxLines="1" android:layout_toRightOf="@+id/rl_user_avatar" app:typeface="normal"/>
        <com.fotoable.youtube.music.ui.view.LaToTextView android:textSize="12sp" android:textColor="@color/color_9b9b9b" android:ellipsize="end" android:id="@+id/tv_post_time" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginLeft="8dp" android:text="3 min" android:maxLines="1" android:layout_toRightOf="@+id/rl_user_avatar" android:layout_alignParentBottom="true" app:typeface="normal"/>
    </RelativeLayout>
    <com.fotoable.youtube.music.ui.view.LaToTextView android:textSize="15sp" android:textColor="@color/color_282828" android:autoLink="all" android:id="@+id/tv_post_content" android:paddingLeft="10dp" android:paddingRight="10dp" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginLeft="48dp" android:layout_marginTop="12dp" android:text="帖子内容" app:typeface="normal"/>
    <android.support.v7.widget.RecyclerView android:id="@+id/rv_post_image" android:paddingLeft="10dp" android:paddingRight="10dp" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginLeft="48dp" android:layout_marginTop="12dp"/>
    <RelativeLayout android:id="@+id/ll_post_video" android:background="@color/color_f6f6f6" android:layout_width="match_parent" android:layout_height="54dp" android:layout_marginLeft="58dp" android:layout_marginTop="12dp" android:layout_marginRight="10dp">
        <RelativeLayout android:layout_width="70dp" android:layout_height="40dp" android:layout_marginLeft="12dp" android:layout_centerVertical="true">
            <ImageView android:id="@+id/iv_post_video_cover" android:layout_width="match_parent" android:layout_height="match_parent" android:src="@mipmap/pic_recently" android:scaleType="centerCrop"/>
            <View android:background="@color/transparent_black_30" android:layout_width="match_parent" android:layout_height="match_parent"/>
            <ImageView android:layout_width="16dp" android:layout_height="16dp" android:src="@mipmap/notifi_icon_play" android:layout_centerInParent="true"/>
            <com.fotoable.youtube.music.ui.view.LaToTextView android:textSize="7sp" android:textColor="@color/white" android:gravity="center" android:id="@+id/tv_post_video_time" android:background="#b9000000" android:paddingLeft="5dp" android:paddingRight="5dp" android:visibility="gone" android:layout_width="wrap_content" android:layout_height="15dp" android:text="4:32" android:layout_alignRight="@+id/iv_icon" android:layout_alignBottom="@+id/iv_icon" android:layout_alignParentRight="true" android:layout_alignParentBottom="true"/>
        </RelativeLayout>
        <LinearLayout android:orientation="vertical" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginLeft="94dp" android:layout_centerVertical="true">
            <com.fotoable.youtube.music.ui.view.LaToTextView android:textSize="14sp" android:textColor="#2b2525" android:ellipsize="end" android:id="@+id/tv_post_video_title" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="-2dp" android:text="Type something ab Video Name" android:maxLines="2" android:layout_weight="1" app:typeface="normal"/>
            <com.fotoable.youtube.music.ui.view.LaToTextView android:textSize="12sp" android:textColor="#ff676767" android:ellipsize="end" android:id="@+id/tv_post_video_artists" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="0dp" android:text="Type something ab Video Name" android:maxLines="1" android:layout_weight="1" app:typeface="normal"/>
        </LinearLayout>
    </RelativeLayout>
    <RelativeLayout android:layout_width="match_parent" android:layout_height="50dp">
        <LinearLayout android:gravity="center_vertical" android:orientation="horizontal" android:paddingLeft="10dp" android:paddingRight="10dp" android:layout_width="match_parent" android:layout_height="50dp" android:layout_marginLeft="48dp">
            <LinearLayout android:gravity="center_vertical" android:orientation="horizontal" android:id="@+id/ll_post_like" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1"/>
            <LinearLayout android:gravity="center_vertical" android:orientation="horizontal" android:id="@+id/ll_post_comment" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1">
                <ImageView android:layout_width="wrap_content" android:layout_height="wrap_content" android:src="@drawable/icon_comment_dark"/>
                <com.fotoable.youtube.music.ui.view.LaToTextView android:textSize="12sp" android:textColor="@color/color_9b9b9b" android:id="@+id/tv_post_comment_count" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginLeft="8dp" android:text="2" app:typeface="normal"/>
            </LinearLayout>
            <LinearLayout android:gravity="center_vertical" android:orientation="horizontal" android:id="@+id/ll_post_delete_report" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1">
                <ImageView android:id="@+id/iv_delete_report" android:layout_width="wrap_content" android:layout_height="wrap_content" android:src="@drawable/icon_report"/>
                <com.fotoable.youtube.music.ui.view.LaToTextView android:textSize="12sp" android:textColor="@color/color_9b9b9b" android:id="@+id/tv_delete_report" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginLeft="8dp" android:text="@string/report" app:typeface="normal"/>
            </LinearLayout>
        </LinearLayout>
        <RelativeLayout android:gravity="center_vertical" android:orientation="horizontal" android:layout_width="wrap_content" android:layout_height="match_parent" android:layout_marginLeft="43dp">
            <ImageView android:id="@+id/iv_post_like" android:visibility="visible" android:layout_width="15dp" android:layout_height="15dp" android:layout_marginLeft="15dp" android:src="@drawable/bt_comment_like" android:layout_centerVertical="true"/>
            <com.airbnb.lottie.LottieAnimationView android:id="@+id/lav_like_anim" android:layout_width="45dp" android:layout_height="45dp" android:layout_centerVertical="true" app:lottie_imageAssetsFolder="post_like.json" app:lottie_progress="100"/>
            <com.fotoable.youtube.music.ui.view.LaToTextView android:textSize="12sp" android:textColor="@color/color_9b9b9b" android:id="@+id/tv_post_like_count" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginLeft="38dp" android:text="10" android:layout_centerVertical="true" app:typeface="normal"/>
        </RelativeLayout>
    </RelativeLayout>
    <View android:id="@+id/gap_view" android:background="@color/color_fafafa" android:visibility="gone" android:layout_width="match_parent" android:layout_height="14dp"/>
</LinearLayout>
