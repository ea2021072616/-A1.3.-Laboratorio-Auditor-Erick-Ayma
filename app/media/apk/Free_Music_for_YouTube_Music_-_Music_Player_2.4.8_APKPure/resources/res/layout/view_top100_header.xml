<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto" android:orientation="vertical" android:layout_width="match_parent" android:layout_height="wrap_content">
    <LinearLayout android:gravity="center_horizontal" android:orientation="horizontal" android:background="@color/white" android:paddingLeft="16dp" android:paddingTop="16dp" android:paddingRight="16dp" android:paddingBottom="16dp" android:visibility="visible" android:layout_width="match_parent" android:layout_height="wrap_content">
        <RelativeLayout android:id="@+id/featured_charts_view" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1">
            <com.fotoable.youtube.music.ui.view.CustomImageView android:layout_width="match_parent" android:layout_height="wrap_content" android:src="@mipmap/fast_charts"/>
            <com.fotoable.youtube.music.ui.view.LaToTextView android:textSize="15sp" android:textColor="@color/white" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/rank" android:layout_centerInParent="true" app:typeface="monospace"/>
        </RelativeLayout>
        <View android:layout_gravity="center" android:layout_width="14dp" android:layout_height="1dp"/>
        <RelativeLayout android:id="@+id/featured_artists_view" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1">
            <com.fotoable.youtube.music.ui.view.CustomImageView android:layout_width="match_parent" android:layout_height="wrap_content" android:src="@mipmap/fast_artists"/>
            <com.fotoable.youtube.music.ui.view.LaToTextView android:textSize="15sp" android:textColor="@color/white" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/artists" android:layout_centerInParent="true" app:typeface="monospace"/>
        </RelativeLayout>
        <View android:layout_gravity="center" android:layout_width="14dp" android:layout_height="1dp"/>
        <RelativeLayout android:id="@+id/featured_genres_view" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1">
            <com.fotoable.youtube.music.ui.view.CustomImageView android:layout_width="match_parent" android:layout_height="wrap_content" android:src="@mipmap/fast_genres"/>
            <com.fotoable.youtube.music.ui.view.LaToTextView android:textSize="15sp" android:textColor="@color/white" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/genres" android:layout_centerInParent="true" app:typeface="monospace"/>
        </RelativeLayout>
    </LinearLayout>
    <View android:background="@color/line_color" android:layout_width="match_parent" android:layout_height="0.5dp"/>
</LinearLayout>
