<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto" android:orientation="vertical" android:background="@color/white" android:layout_width="match_parent" android:layout_height="wrap_content">
    <RelativeLayout android:id="@+id/music_info_panel" android:layout_width="match_parent" android:layout_height="87dp" android:layout_below="@+id/tool_bar_panel">
        <ImageView android:id="@+id/music_cover" android:layout_width="110dp" android:layout_height="62dp" android:layout_marginLeft="16dp" android:src="@mipmap/pic_recently" android:layout_centerVertical="true"/>
        <LinearLayout android:orientation="vertical" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginLeft="8dp" android:layout_toLeftOf="@+id/chevron_right" android:layout_toRightOf="@+id/music_cover" android:layout_centerVertical="true">
            <com.fotoable.youtube.music.ui.view.LaToTextView android:textSize="14sp" android:textColor="#2b2525" android:ellipsize="end" android:id="@+id/music_title" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Type something ab Video Name" android:maxLines="2" android:layout_weight="1" app:typeface="normal"/>
            <com.fotoable.youtube.music.ui.view.LaToTextView android:textSize="12sp" android:textColor="#ff676767" android:ellipsize="end" android:id="@+id/artists_name" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="6dp" android:text="Type something ab Video Name" android:maxLines="1" android:layout_weight="1" app:typeface="normal"/>
        </LinearLayout>
        <ImageView android:id="@+id/chevron_right" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginRight="16dp" android:src="@mipmap/chevron_right" android:layout_alignParentRight="true" android:layout_centerVertical="true"/>
    </RelativeLayout>
    <RelativeLayout android:id="@+id/comment_list_title" android:background="#fafafa" android:visibility="visible" android:layout_width="match_parent" android:layout_height="36dp">
        <com.fotoable.youtube.music.ui.view.LaToTextView android:textSize="14sp" android:textColor="#ff676767" android:ellipsize="end" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginLeft="16dp" android:layout_marginTop="6dp" android:layout_marginBottom="6dp" android:text="@string/comments" android:maxLines="1" android:layout_weight="1" android:layout_alignParentBottom="true" app:typeface="normal"/>
        <LinearLayout android:gravity="center_vertical" android:orientation="horizontal" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginRight="0dp" android:layout_alignParentRight="true" android:layout_alignParentBottom="true">
            <com.fotoable.youtube.music.ui.view.LaToTextView android:textSize="14sp" android:textColor="@color/color_4a4a4a" android:gravity="bottom" android:id="@+id/type_hot" android:paddingLeft="8dp" android:paddingRight="8dp" android:paddingBottom="6dp" android:layout_width="wrap_content" android:layout_height="36dp" android:text="@string/hot" app:typeface="normal"/>
            <View android:layout_gravity="bottom" android:background="@color/color_c8c7cc" android:layout_width="1dp" android:layout_height="15dp" android:layout_marginBottom="6dp"/>
            <com.fotoable.youtube.music.ui.view.LaToTextView android:textSize="14sp" android:textColor="@color/color_c8c7cc" android:gravity="bottom" android:id="@+id/type_new" android:paddingLeft="8dp" android:paddingRight="16dp" android:paddingBottom="6dp" android:layout_width="wrap_content" android:layout_height="36dp" android:text="@string/new1" app:typeface="normal"/>
        </LinearLayout>
    </RelativeLayout>
    <com.fotoable.youtube.music.ui.view.LaToTextView android:textSize="14sp" android:textColor="#ff676767" android:gravity="center" android:id="@+id/no_data_view" android:background="#fafafa" android:paddingLeft="16dp" android:paddingTop="54dp" android:paddingRight="16dp" android:visibility="gone" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="@string/no_one_commented_yet_write_your_comment_now" android:layout_centerInParent="true" app:typeface="normal"/>
</LinearLayout>
