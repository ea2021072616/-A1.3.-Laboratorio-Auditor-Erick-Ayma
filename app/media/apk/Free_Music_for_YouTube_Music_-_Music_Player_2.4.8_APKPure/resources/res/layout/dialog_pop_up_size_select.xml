<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto" android:orientation="vertical" android:layout_width="match_parent" android:layout_height="wrap_content">
    <LinearLayout android:gravity="center_horizontal" android:orientation="vertical" android:background="@drawable/bg_white_radius_3dp" android:paddingTop="20dp" android:paddingBottom="30dp" android:layout_width="310dp" android:layout_height="wrap_content">
        <com.fotoable.youtube.music.ui.view.LaToTextView android:textSize="15sp" android:textColor="@color/color_2b2525" android:id="@+id/content" android:paddingLeft="18dp" android:paddingRight="18dp" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/choose_the_size_of_the_pop_up_player" app:typeface="monospace"/>
        <View android:background="@color/color_d9cfd1" android:layout_width="match_parent" android:layout_height="0.5dp" android:layout_marginTop="20dp"/>
        <RelativeLayout android:id="@+id/rl_small" android:paddingLeft="18dp" android:paddingRight="18dp" android:layout_width="match_parent" android:layout_height="48dp">
            <com.fotoable.youtube.music.ui.view.LaToTextView android:textSize="15sp" android:textColor="@color/color_2b2525" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/small" android:layout_centerVertical="true" app:typeface="normal"/>
            <CheckBox android:gravity="center_vertical" android:id="@+id/ck_small" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginRight="4dp" android:checked="false" android:layout_alignParentRight="true" android:layout_centerVertical="true" style="@style/CustomCheckBoxTheme2"/>
        </RelativeLayout>
        <View android:background="@color/color_d9cfd1" android:layout_width="match_parent" android:layout_height="0.5dp"/>
        <RelativeLayout android:id="@+id/rl_medium" android:paddingLeft="18dp" android:paddingRight="18dp" android:layout_width="match_parent" android:layout_height="48dp">
            <com.fotoable.youtube.music.ui.view.LaToTextView android:textSize="15sp" android:textColor="@color/color_2b2525" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/medium" android:layout_centerVertical="true" app:typeface="normal"/>
            <CheckBox android:gravity="center_vertical" android:id="@+id/ck_medium" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginRight="4dp" android:layout_alignParentRight="true" android:layout_centerVertical="true" style="@style/CustomCheckBoxTheme2"/>
        </RelativeLayout>
        <View android:background="@color/color_d9cfd1" android:layout_width="match_parent" android:layout_height="0.5dp"/>
        <RelativeLayout android:id="@+id/rl_big" android:paddingLeft="18dp" android:paddingRight="18dp" android:layout_width="match_parent" android:layout_height="48dp">
            <com.fotoable.youtube.music.ui.view.LaToTextView android:textSize="15sp" android:textColor="@color/color_2b2525" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/big" android:layout_centerVertical="true" app:typeface="normal"/>
            <CheckBox android:gravity="center_vertical" android:id="@+id/ck_big" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginRight="4dp" android:layout_alignParentRight="true" android:layout_centerVertical="true" style="@style/CustomCheckBoxTheme2"/>
        </RelativeLayout>
        <View android:background="@color/color_d9cfd1" android:layout_width="match_parent" android:layout_height="0.5dp"/>
        <RelativeLayout android:id="@+id/rl_max" android:paddingLeft="18dp" android:paddingRight="18dp" android:layout_width="match_parent" android:layout_height="48dp">
            <com.fotoable.youtube.music.ui.view.LaToTextView android:textSize="15sp" android:textColor="@color/color_2b2525" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/max" android:layout_centerVertical="true" app:typeface="normal"/>
            <CheckBox android:gravity="center_vertical" android:id="@+id/ck_max" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginRight="4dp" android:layout_alignParentRight="true" android:layout_centerVertical="true" style="@style/CustomCheckBoxTheme2"/>
        </RelativeLayout>
        <View android:background="@color/color_d9cfd1" android:layout_width="match_parent" android:layout_height="0.5dp"/>
        <LinearLayout android:orientation="horizontal" android:layout_width="match_parent" android:layout_height="36dp" android:layout_marginLeft="18dp" android:layout_marginTop="32dp" android:layout_marginRight="18dp">
            <com.fotoable.youtube.music.ui.view.LaToTextView android:textSize="15sp" android:textColor="@color/color_b6afb0" android:gravity="center" android:id="@+id/cancel" android:background="@drawable/bt_cancel_border" android:layout_width="0dp" android:layout_height="36dp" android:text="@string/cancel" android:layout_weight="1" app:typeface="monospace"/>
            <View android:layout_width="18dp" android:layout_height="1dp"/>
            <com.fotoable.youtube.music.ui.view.LaToTextView android:textSize="15sp" android:textColor="@color/white" android:gravity="center" android:id="@+id/clear" android:background="@drawable/bt_clear_border" android:layout_width="0dp" android:layout_height="36dp" android:text="@string/ok" android:layout_weight="1" app:typeface="monospace"/>
        </LinearLayout>
    </LinearLayout>
</LinearLayout>
