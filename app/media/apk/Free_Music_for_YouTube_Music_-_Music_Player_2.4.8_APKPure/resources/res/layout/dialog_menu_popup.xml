<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto" android:orientation="vertical" android:background="@android:color/white" android:paddingTop="14dp" android:paddingBottom="16dp" android:layout_width="match_parent" android:layout_height="match_parent">
    <LinearLayout android:orientation="horizontal" android:id="@+id/ll_favorite" android:background="@drawable/click_status_f5f0f1" android:paddingRight="16dp" android:layout_width="match_parent" android:layout_height="49dp">
        <CheckBox android:layout_gravity="center_vertical" android:id="@+id/btn_favorite" android:background="@drawable/favorite_like_bg" android:layout_width="24dp" android:layout_height="24dp" android:layout_marginLeft="18dp" style="@style/favorite_check"/>
        <com.fotoable.youtube.music.ui.view.LaToTextView android:textSize="16sp" android:textColor="#4a4a4a" android:layout_gravity="center_vertical" android:id="@+id/favorite_label" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginLeft="18dp" android:text="@string/add_to_favorite" app:typeface="normal"/>
    </LinearLayout>
    <LinearLayout android:orientation="horizontal" android:id="@+id/play_now" android:background="@drawable/click_status_f5f0f1" android:paddingRight="16dp" android:visibility="gone" android:layout_width="match_parent" android:layout_height="46dp">
        <ImageView android:layout_gravity="center_vertical" android:background="@mipmap/icon_playnow" android:layout_width="24dp" android:layout_height="24dp" android:layout_marginLeft="16dp" android:scaleType="centerCrop"/>
        <com.fotoable.youtube.music.ui.view.LaToTextView android:textSize="16sp" android:textColor="#4a4a4a" android:layout_gravity="center_vertical" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginLeft="16dp" android:text="@string/play_now" app:typeface="normal"/>
    </LinearLayout>
    <LinearLayout android:orientation="horizontal" android:id="@+id/play_next" android:background="@drawable/click_status_f5f0f1" android:paddingRight="16dp" android:layout_width="match_parent" android:layout_height="46dp">
        <ImageView android:layout_gravity="center_vertical" android:background="@mipmap/icon_playnext_discover" android:layout_width="24dp" android:layout_height="24dp" android:layout_marginLeft="16dp" android:scaleType="centerCrop"/>
        <com.fotoable.youtube.music.ui.view.LaToTextView android:textSize="16sp" android:textColor="#4a4a4a" android:layout_gravity="center_vertical" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginLeft="16dp" android:text="@string/play_next" app:typeface="normal"/>
    </LinearLayout>
    <LinearLayout android:orientation="horizontal" android:id="@+id/add_to_queue" android:background="@drawable/click_status_f5f0f1" android:paddingRight="16dp" android:visibility="gone" android:layout_width="match_parent" android:layout_height="46dp">
        <ImageView android:layout_gravity="center_vertical" android:background="@mipmap/icon_addtoqueue" android:layout_width="24dp" android:layout_height="24dp" android:layout_marginLeft="16dp" android:scaleType="centerCrop"/>
        <com.fotoable.youtube.music.ui.view.LaToTextView android:textSize="16sp" android:textColor="#4a4a4a" android:layout_gravity="center_vertical" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginLeft="16dp" android:text="@string/add_to_the_queue" app:typeface="normal"/>
    </LinearLayout>
    <RelativeLayout android:paddingRight="16dp" android:layout_width="match_parent" android:layout_height="wrap_content">
        <LinearLayout android:orientation="horizontal" android:id="@+id/add_to_playlist" android:background="@drawable/click_status_f5f0f1" android:layout_width="match_parent" android:layout_height="46dp">
            <ImageView android:layout_gravity="center_vertical" android:background="@mipmap/icon_addtoplaylist" android:layout_width="24dp" android:layout_height="24dp" android:layout_marginLeft="16dp" android:scaleType="centerCrop"/>
            <RelativeLayout android:layout_gravity="center_vertical" android:layout_width="wrap_content" android:layout_height="wrap_content">
                <com.fotoable.youtube.music.ui.view.LaToTextView android:textSize="16sp" android:textColor="#4a4a4a" android:id="@+id/dialog_add_playlist_tx" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginLeft="16dp" android:text="@string/add_to_my_playlist" app:typeface="normal"/>
            </RelativeLayout>
        </LinearLayout>
        <ImageView android:id="@+id/dialog_add_playlist_tips_img" android:visibility="gone" android:layout_width="6dp" android:layout_height="6dp" android:layout_marginLeft="35dp" android:layout_marginTop="12dp" android:src="@drawable/shape_corne_red"/>
    </RelativeLayout>
    <LinearLayout android:orientation="horizontal" android:id="@+id/lin_share_to_community" android:background="@drawable/click_status_f5f0f1" android:paddingRight="16dp" android:visibility="gone" android:layout_width="match_parent" android:layout_height="46dp">
        <ImageView android:layout_gravity="center_vertical" android:background="@drawable/icon_make_post" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginLeft="16dp"/>
        <com.fotoable.youtube.music.ui.view.LaToTextView android:textSize="16sp" android:textColor="#4a4a4a" android:layout_gravity="center_vertical" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginLeft="16dp" android:text="@string/community_post_title" app:typeface="normal"/>
        <ImageView android:id="@+id/dialog_post_tips_img" android:visibility="gone" android:layout_width="6dp" android:layout_height="6dp" android:layout_marginLeft="2dp" android:layout_marginTop="14dp" android:src="@drawable/shape_corne_red"/>
    </LinearLayout>
    <RelativeLayout android:id="@+id/lin_comment" android:background="@drawable/click_status_f5f0f1" android:paddingRight="16dp" android:visibility="gone" android:layout_width="match_parent" android:layout_height="wrap_content">
        <LinearLayout android:orientation="horizontal" android:background="@drawable/click_status_f5f0f1" android:layout_width="match_parent" android:layout_height="46dp">
            <ImageView android:layout_gravity="center_vertical" android:background="@drawable/icon_menu_comments" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginLeft="16dp" android:scaleType="centerCrop"/>
            <RelativeLayout android:layout_gravity="center_vertical" android:layout_width="wrap_content" android:layout_height="wrap_content">
                <com.fotoable.youtube.music.ui.view.LaToTextView android:textSize="16sp" android:textColor="#4a4a4a" android:id="@+id/comment_title" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginLeft="16dp" android:text="@string/comment" app:typeface="normal"/>
                <com.fotoable.youtube.music.ui.view.LaToTextView android:textSize="16sp" android:textColor="#4a4a4a" android:id="@+id/comment_count" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="" android:layout_toRightOf="@+id/comment_title" app:typeface="normal"/>
            </RelativeLayout>
        </LinearLayout>
        <ImageView android:id="@+id/dialog_comment_tips_img" android:visibility="gone" android:layout_width="6dp" android:layout_height="6dp" android:layout_marginLeft="36dp" android:layout_marginTop="12dp" android:src="@drawable/shape_corne_red"/>
    </RelativeLayout>
    <LinearLayout android:orientation="horizontal" android:id="@+id/lin_share" android:background="@drawable/click_status_f5f0f1" android:paddingRight="16dp" android:visibility="visible" android:layout_width="match_parent" android:layout_height="46dp">
        <ImageView android:layout_gravity="center_vertical" android:background="@mipmap/icon_share" android:layout_width="24dp" android:layout_height="24dp" android:layout_marginLeft="16dp" android:scaleType="centerCrop"/>
        <com.fotoable.youtube.music.ui.view.LaToTextView android:textSize="16sp" android:textColor="#4a4a4a" android:layout_gravity="center_vertical" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginLeft="16dp" android:text="@string/share" app:typeface="normal"/>
    </LinearLayout>
    <LinearLayout android:orientation="horizontal" android:id="@+id/lin_artist" android:background="@drawable/click_status_f5f0f1" android:paddingRight="16dp" android:visibility="gone" android:layout_width="match_parent" android:layout_height="46dp">
        <ImageView android:layout_gravity="center_vertical" android:background="@mipmap/icon_artist" android:layout_width="24dp" android:layout_height="24dp" android:layout_marginLeft="16dp" android:scaleType="centerCrop"/>
        <com.fotoable.youtube.music.ui.view.LaToTextView android:textSize="16sp" android:textColor="#4a4a4a" android:ellipsize="end" android:layout_gravity="center_vertical" android:id="@+id/txt_artists" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginLeft="16dp" android:text="@string/artist" android:maxLines="1" app:typeface="normal"/>
    </LinearLayout>
    <LinearLayout android:orientation="horizontal" android:id="@+id/lin_copy_url" android:background="@drawable/click_status_f5f0f1" android:paddingRight="16dp" android:layout_width="match_parent" android:layout_height="46dp">
        <ImageView android:layout_gravity="center_vertical" android:background="@mipmap/icon_copy_url" android:layout_width="24dp" android:layout_height="24dp" android:layout_marginLeft="16dp" android:scaleType="centerCrop"/>
        <com.fotoable.youtube.music.ui.view.LaToTextView android:textSize="16sp" android:textColor="#4a4a4a" android:layout_gravity="center_vertical" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginLeft="16dp" android:text="@string/copy_url" app:typeface="normal"/>
    </LinearLayout>
    <LinearLayout android:orientation="horizontal" android:id="@+id/ll_sleep_time" android:background="@drawable/click_status_f5f0f1" android:paddingRight="16dp" android:visibility="gone" android:layout_width="match_parent" android:layout_height="46dp">
        <ImageView android:layout_gravity="center_vertical" android:background="@mipmap/red_sleep_timer" android:layout_width="24dp" android:layout_height="24dp" android:layout_marginLeft="16dp" android:scaleType="centerCrop"/>
        <com.fotoable.youtube.music.ui.view.LaToTextView android:textSize="16sp" android:textColor="#4a4a4a" android:layout_gravity="center_vertical" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginLeft="16dp" android:text="@string/sleep_timer" app:typeface="normal"/>
        <com.fotoable.youtube.music.ui.view.LaToTextView android:textSize="12sp" android:textColor="@color/color_969297" android:gravity="right" android:layout_gravity="center_vertical" android:id="@+id/sleep_timer_real_time" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginLeft="16dp" android:layout_marginRight="16dp" app:typeface="normal"/>
    </LinearLayout>
    <LinearLayout android:orientation="horizontal" android:id="@+id/lin_find_lyric" android:background="@drawable/click_status_f5f0f1" android:paddingRight="16dp" android:layout_width="match_parent" android:layout_height="46dp">
        <ImageView android:layout_gravity="center_vertical" android:background="@mipmap/icon_findlyric" android:layout_width="24dp" android:layout_height="24dp" android:layout_marginLeft="16dp" android:scaleType="centerCrop"/>
        <com.fotoable.youtube.music.ui.view.LaToTextView android:textSize="16sp" android:textColor="#4a4a4a" android:layout_gravity="center_vertical" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginLeft="16dp" android:text="@string/find_lyric" app:typeface="normal"/>
    </LinearLayout>
    <LinearLayout android:orientation="horizontal" android:id="@+id/lin_find_mp3" android:background="@drawable/click_status_f5f0f1" android:paddingRight="16dp" android:layout_width="match_parent" android:layout_height="46dp">
        <ImageView android:layout_gravity="center_vertical" android:background="@mipmap/icon_find_mp3" android:layout_width="24dp" android:layout_height="24dp" android:layout_marginLeft="16dp" android:scaleType="centerCrop"/>
        <com.fotoable.youtube.music.ui.view.LaToTextView android:textSize="16sp" android:textColor="#4a4a4a" android:layout_gravity="center_vertical" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginLeft="16dp" android:text="@string/find_mp3" app:typeface="normal"/>
    </LinearLayout>
    <LinearLayout android:orientation="horizontal" android:id="@+id/lin_delete" android:background="@drawable/click_status_f5f0f1" android:paddingRight="16dp" android:visibility="gone" android:layout_width="match_parent" android:layout_height="46dp">
        <ImageView android:layout_gravity="center_vertical" android:background="@mipmap/icon_delete" android:layout_width="24dp" android:layout_height="24dp" android:layout_marginLeft="16dp" android:scaleType="centerCrop"/>
        <com.fotoable.youtube.music.ui.view.LaToTextView android:textSize="16sp" android:textColor="#4a4a4a" android:layout_gravity="center_vertical" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginLeft="16dp" android:text="@string/delete" app:typeface="normal"/>
    </LinearLayout>
    <LinearLayout android:orientation="horizontal" android:id="@+id/lin_admin_delete" android:background="@drawable/click_status_f5f0f1" android:paddingRight="16dp" android:visibility="gone" android:layout_width="match_parent" android:layout_height="46dp">
        <ImageView android:layout_gravity="center_vertical" android:background="@mipmap/icon_delete" android:layout_width="24dp" android:layout_height="24dp" android:layout_marginLeft="16dp" android:scaleType="centerCrop"/>
        <com.fotoable.youtube.music.ui.view.LaToTextView android:textSize="16sp" android:textColor="#4a4a4a" android:layout_gravity="center_vertical" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginLeft="16dp" android:text="@string/offline_songs" app:typeface="normal"/>
    </LinearLayout>
</LinearLayout>
